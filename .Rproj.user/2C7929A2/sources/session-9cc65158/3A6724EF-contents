class training_tyentry_moran(data.Dataset):
    def __init__(self, comp_path, selist=None, prop=1, size_w=256, size_h=256, flip=0):
        super(training_tyentry_moran, self).__init__()
        list = [x for x in os.listdir(comp_path) ]
        self.list=[s for s in list if re.search('\\.npz$',s)] 
        if selist is not None:
           self.list=selist 
        self.comp_path = comp_path 
        self.size_w = size_w 
        self.size_h = size_h 
        self.flip = flip 

    def __getitem__(self, index): 
        complex_fpath = os.path.join(self.comp_path + '/', self.list[index])
        assert os.path.exists(complex_fpath) 
        try:
            alldata=np.load(complex_fpath,allow_pickle=True)
            tsample_orgimg=alldata['orgimg'].astype(np.float32)/256.0
            tsample_img=alldata['img']
            tsample_m21=alldata['m21']
            tsample_m15=alldata['m15']
            tsample_m11=alldata['m11']
            tsample_m7=alldata['m7']
            tsample_m5=alldata['m5'] 
            tsample_e21=alldata['e21']
            tsample_e15=alldata['e15']
            tsample_e11=alldata['e11']
            tsample_e7=alldata['e7']
            tsample_e5=alldata['e5'] 

            tsample_img = np.moveaxis(tsample_img, -1, 0)
            tsample_orgimg = np.moveaxis(tsample_orgimg, -1, 0)
            tsample_complex=np.stack([tsample_m21,tsample_m15,tsample_m11,tsample_m7,tsample_m5,
                               tsample_e21,tsample_e15,tsample_e11,tsample_e7,tsample_e5])
        except OSError:
