class indatapred_dataset(data.Dataset):
    def __init__(self, data_path=''):
        super(indatapred_dataset, self).__init__()
        list = [x for x in os.listdir(data_path) ]
        self.list = [f  for f in list if re.search('\\.npz$', f)] 
        self.data_path = data_path

    def __getitem__(self, index):
        mask_path = os.path.join(self.data_path + '/', self.list[index])
        assert os.path.exists(mask_path) 
        try:
          adata=np.load(mask_path,allow_pickle=True)
          tsample_img=adata['img'].astype(np.float32)/256.0
          mask=adata['mask'] 
          mask=mask[None,:,:] 
          tsample_img = np.moveaxis(tsample_img, -1, 0)
        except OSError:
          return None, None, None
        #print('tsample_img.dtype, mask.dtype: ',tsample_img.shape,';', tsample_img.dtype,';',mask.shape,';',mask.dtype)
        return tsample_img,mask, self.list[index]
      
    def __len__(self):
        return len(self.list) 


