class allcls_sampler(Sampler):
    def __init__(self,batch_size=1, train_index=None,test_index=None,indtest_index=None,shuffle=False):
        if shuffle:
            if train_index is not None: 
                np.random.shuffle(train_index)
            if test_index is not None: 
                np.random.shuffle(test_index)  
            if indtest_index is not None: 
                np.random.shuffle(indtest_index)   
        self.train_index=train_index 
        self.test_index=test_index 
        self.indtest_index=indtest_index 
        self.batch_size_test=math.ceil(batch_size*len(test_index)/(len(train_index)*1.0))
        self.batch_size_indtest = math.ceil(batch_size*len(indtest_index)/(len(train_index)*1.0))
        self.batche_size = math.ceil((1.0*len(train_index))/batch_size)
        print('batch_size train:',batch_size,';test batch size:',self.batch_size_test,
                         ';ind test batch size:',self.batch_size_indtest)
        self.batch_size=batch_size
        self.nbatch=batch_size=math.ceil(len(self.train_index)/(1.0*batch_size))

    def __iter__(self):
        ntrain,ntest=len(self.train_index),len(self.test_index)
        for i, start_idx in enumerate(range(0, len(self.train_index), self.batch_size)):
            end_idx = min(start_idx + self.batch_size, len(self.train_index))
            excerpt_train = self.train_index[start_idx:end_idx]
            start_idx_t=i*self.batch_size_test
            end_idx_t = min(start_idx_t + self.batch_size_test, len(self.test_index))
            excerpt_test = self.test_index[start_idx_t:end_idx_t]
            start_idx_t=i*self.batch_size_indtest
            end_idx_t = min(start_idx_t + self.batch_size_indtest, len(self.indtest_index))
            excerpt_indtest = self.indtest_index[start_idx_t:end_idx_t]
            excerpt_list=[i  for i in excerpt_train]
            excerpt_list.extend([i + ntrain  for i in excerpt_test])
            excerpt_list.extend([i + ntrain + ntest  for i in excerpt_indtest])
#            print('excerpt_list len',len(excerpt_list))
            yield excerpt_list 

    def __len__(self):
        return self.nbatch 


