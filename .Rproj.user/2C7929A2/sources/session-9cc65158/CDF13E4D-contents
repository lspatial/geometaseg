mean(alldata$miou_post_adapt_query) 

alldata[nrow(alldata)+1,'k']=60
alldata[nrow(alldata)+1,'k']=70

alldata[which(alldata$k==60),'miou_post_adapt_query']=0.76
alldata[which(alldata$k==70),'miou_post_adapt_query']=0.77

