par(mfrow=c(1,2),mar=c(4,4,1,1))
alldata=alldata[order(alldata$k),]
plot(alldata$k,alldata$miou_post_adapt_query,type="l",col="red",xlab="a. Number of shots \n(red: query; blue: support)",lwd=2,
