import numpy as np  
import matplotlib.pyplot as plt
import matplotlib 
matplotlib.use('Agg')
import matplotlib.image as mpimg
import glob
from pathlib import Path 
import pandas as pd 
import os 
import re 
from PIL import Image

rpath='/geosampling/predict3'
tfls=glob.glob(rpath+'/*.npz')
tflDf=pd.DataFrame({'fpath':tfls})
tflDf['base']=[Path(f).stem for f in tfls]
tflDf=tflDf.sort_values(by=['base'])

trPath='/geosampling/predict3_png' 
if not os.path.exists(trPath):
    os.makedirs(trPath)
for i in range(tflDf.shape[0]):
  tfl=tflDf.iloc[i]['fpath']
  bname=tflDf.iloc[i]['base'] 
  ex=re.sub('\_imgcom.*','',bname)
  trPath_sub=trPath+'/'+ex
  if not os.path.exists(trPath_sub):
    os.makedirs(trPath_sub)
  adata=np.load(tfl)
  img=adata['img'] 
  truemask=adata['truemask']
  premask=adata['premask']
  img=np.moveaxis(img,0,-1)
  img = img.astype(np.uint8)
  tfl=trPath_sub+'/'+bname+'_img.png'
#  im = Image.fromarray(img)
#  im.save(tfl)
  mpimg.imsave(tfl, img)
  tfl=trPath_sub+'/'+bname+'_true.png' 
  mpimg.imsave(tfl, truemask)
  tfl=trPath_sub+'/'+bname+'_premask.png' 
  mpimg.imsave(tfl, premask)
  
  
